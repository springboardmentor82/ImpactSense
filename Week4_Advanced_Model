        "def classify_risk(mag):\n",
        "    if mag < -0.5:\n",
        "        return \"Low\"\n",
        "    elif -0.5 <= mag < 0.5:\n",
        "        return \"Medium\"\n",
        "    else:\n",
        "        return \"High\"\n",
        "\n",
        "df['risk_level'] = df['magnitude'].apply(classify_risk)\n",
        "\n",
        "df['risk_level'].value_counts()"
      ],
